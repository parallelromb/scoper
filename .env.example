# LLM Provider: openai | anthropic | github | ollama
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_MODEL=

# Ollama (when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:27b

# Server
# Default 8005 to avoid clashing with common local FastAPI/PJTales setups on 8000.
PORT=8005
HOST=0.0.0.0

# Database
DB_PATH=data/agentlab.db

# Auth
SESSION_TTL_HOURS=24
DEFAULT_ROLE=estimator

# Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=data/uploads

# Telemetry
TELEMETRY_ENABLED=false

# Smara Memory API (optional)
SMARA_API_URL=
SMARA_API_KEY=
